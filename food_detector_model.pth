# Placeholder model file for food detector
# In production, this would be a trained PyTorch model
# For demo purposes, we'll create a simple placeholder

import torch
import torch.nn as nn

class SimpleFoodDetector(nn.Module):
    def __init__(self):
        super().__init__()
        self.features = nn.Sequential(
            nn.Conv2d(3, 32, 3, padding=1),
            nn.ReLU(),
            nn.AdaptiveAvgPool2d((1, 1)),
            nn.Flatten(),
            nn.Linear(32, 101)  # 101 food classes
        )
    
    def forward(self, x):
        return self.features(x)

# Create and save a simple model
model = SimpleFoodDetector()
torch.save(model.state_dict(), 'food_detector_model.pth')
