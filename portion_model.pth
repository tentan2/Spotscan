# Placeholder model file for portion analyzer
import torch
import torch.nn as nn

class PortionModel(nn.Module):
    def __init__(self):
        super().__init__()
        self.features = nn.Sequential(
            nn.Conv2d(3, 32, 3, padding=1),
            nn.ReLU(),
            nn.AdaptiveAvgPool2d((1, 1)),
            nn.Flatten(),
            nn.Linear(32, 1)  # Portion weight
        )
    
    def forward(self, x):
        return self.features(x)

model = PortionModel()
torch.save(model.state_dict(), 'portion_model.pth')
